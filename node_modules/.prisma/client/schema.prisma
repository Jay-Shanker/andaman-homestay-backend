generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Room {
  id          String          @id @default(uuid())
  name        String
  number      Int             @unique
  type        String
  basePrice   Int
  maxGuests   Int             @default(2)
  description String?
  amenities   String          @default("[]")
  photos      String          @default("[]")
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bookings    Booking[]
  blocks      CalendarBlock[]
  icalFeeds   ICalFeed[]
  gcalEvents  GCalEvent[]
}

model Guest {
  id          String    @id @default(uuid())
  name        String
  phone       String?
  email       String?
  nationality String?
  idType      String?
  idNumber    String?
  notes       String?
  tags        String    @default("[]")
  source      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookings    Booking[]
}

model Booking {
  id              String    @id @default(uuid())
  bookingRef      String    @unique
  roomId          String
  guestId         String
  checkIn         DateTime
  checkOut        DateTime
  nights          Int
  adults          Int       @default(1)
  children        Int       @default(0)
  ratePerNight    Int
  totalAmount     Int
  discount        Int       @default(0)
  finalAmount     Int
  source          String
  externalId      String?
  status          String    @default("confirmed")
  paymentStatus   String    @default("pending")
  specialRequests String?
  internalNotes   String?
  checkedInAt     DateTime?
  checkedOutAt    DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  gcalEventId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  room            Room      @relation(fields: [roomId], references: [id])
  guest           Guest     @relation(fields: [guestId], references: [id])
  payments        Payment[]
}

model Payment {
  id        String   @id @default(uuid())
  bookingId String
  amount    Int
  mode      String
  reference String?
  status    String   @default("completed")
  paidAt    DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])
}

model CalendarBlock {
  id        String   @id @default(uuid())
  roomId    String
  startDate DateTime
  endDate   DateTime
  reason    String
  notes     String?
  syncedTo  String   @default("[]")
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id])
}

model ICalFeed {
  id           String    @id @default(uuid())
  roomId       String
  channel      String
  direction    String
  url          String?
  token        String    @unique
  lastSyncedAt DateTime?
  lastStatus   String    @default("pending")
  lastError    String?
  createdAt    DateTime  @default(now())
  room         Room      @relation(fields: [roomId], references: [id])
}

model GCalEvent {
  id          String   @id @default(uuid())
  roomId      String
  bookingId   String?
  gcalEventId String   @unique
  calendarId  String
  title       String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("active")
  syncedAt    DateTime @default(now())
  room        Room     @relation(fields: [roomId], references: [id])
}

model GCalToken {
  id           String   @id @default("default")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String?
  updatedAt    DateTime @updatedAt
}

model Enquiry {
  id          String    @id @default(uuid())
  name        String
  phone       String?
  email       String?
  source      String
  roomPref    String?
  checkIn     DateTime?
  checkOut    DateTime?
  guests      Int?
  message     String?
  status      String    @default("new")
  convertedTo String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  category    String
  description String
  amount      Int
  date        DateTime @default(now())
  roomId      String?
  receipt     String?
  notes       String?
  createdAt   DateTime @default(now())
}

model SyncLog {
  id        String   @id @default(uuid())
  channel   String
  roomId    String?
  action    String
  status    String
  message   String?
  payload   String?
  createdAt DateTime @default(now())
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String
  role         String    @default("staff")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
